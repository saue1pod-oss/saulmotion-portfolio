# Sanity — Next.js client (public, exposed to browser)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity — Studio (loaded by Vite, must be prefixed with SANITY_STUDIO_)
# Copy these to studio/.env.local as well
SANITY_STUDIO_PROJECT_ID=your_project_id_here
SANITY_STUDIO_DATASET=production

# Sanity — API token for server-side fetches (never expose publicly)
# Create a token at https://www.sanity.io/manage → API → Tokens
SANITY_API_READ_TOKEN=your_read_token_here

# Resend — email sending for /contact form
# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=
